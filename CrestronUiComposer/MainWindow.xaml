<Window x:Class="CrestronUiComposer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Crestron UI Composer"
        Icon="Assets/CrestronUIEditor.ico"
        Width="1500" Height="940"
        MinWidth="1050" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#101719">
  <Grid>
    <wv2:WebView2 x:Name="EditorView" DefaultBackgroundColor="#101719" />
    <Border x:Name="LoadingPanel" Background="#101719">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Crestron UI Composer" Foreground="White" FontSize="26" FontWeight="SemiBold" HorizontalAlignment="Center" />
        <TextBlock Text="Starting editor…" Foreground="#72C7B9" FontSize="14" Margin="0,10,0,0" HorizontalAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
