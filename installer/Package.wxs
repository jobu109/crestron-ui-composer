<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="$(ProductName)"
           Manufacturer="Crestron UI Composer"
           Version="$(AppVersion)"
           UpgradeCode="$(UpgradeCode)"
           Language="1033"
           Scope="perUser"
           InstallerVersion="500">
    <SummaryInformation Description="Standalone HTML5 interface editor for Crestron touch panels" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Crestron UI Composer is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />
    <Icon Id="ApplicationIcon" SourceFile="$(IconPath)" />
    <Property Id="ARPPRODUCTICON" Value="ApplicationIcon" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="$(InstallFolderName)" />
    </StandardDirectory>

    <Files Include="$(PublishDir)\**" Directory="INSTALLFOLDER" />

    <Component Id="ShellIntegration" Directory="INSTALLFOLDER">
      <RegistryValue Root="HKCU" Key="$(RegistryKey)" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
      <RegistryValue Root="HKCU" Key="$(FileAssociationRoot)\.cuiproj" Type="string" Value="CrestronUiComposer.Project" />
      <RegistryValue Root="HKCU" Key="$(FileAssociationRoot)\CrestronUiComposer.Project" Type="string" Value="Crestron UI Composer Project" />
      <RegistryValue Root="HKCU" Key="$(FileAssociationRoot)\CrestronUiComposer.Project\DefaultIcon" Type="string" Value="[INSTALLFOLDER]CrestronUiComposer.exe,0" />
      <RegistryValue Root="HKCU" Key="$(FileAssociationRoot)\CrestronUiComposer.Project\shell\open\command" Type="string" Value="&quot;[INSTALLFOLDER]CrestronUiComposer.exe&quot; &quot;%1&quot;" />
      <Shortcut Id="StartMenuShortcut" Directory="ProgramMenuFolder" Name="$(ProductName)" Target="[INSTALLFOLDER]CrestronUiComposer.exe" WorkingDirectory="INSTALLFOLDER" Icon="ApplicationIcon" />
      <Shortcut Id="DesktopShortcut" Directory="DesktopFolder" Name="$(ProductName)" Target="[INSTALLFOLDER]CrestronUiComposer.exe" WorkingDirectory="INSTALLFOLDER" Icon="ApplicationIcon" />
    </Component>
  </Package>
</Wix>
